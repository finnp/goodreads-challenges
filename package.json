{
  "name": "goodreads-news",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape": "tsx scripts/build.ts",
    "build:web": "npm run build --prefix web",
    "build": "npm run build:web",
    "scrape:build": "npm run scrape && npm run build:web",
    "dev": "npm run dev --prefix web",
    "deploy:netlify": "npm run build && npx netlify-cli deploy --prod --dir web/dist",
    "plot:scatter": "tsx scripts/scatter-rating-pages.ts"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "cheerio": "^1.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
